# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ─────────────────────────────────────────────
# Environnements virtuels
# ─────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─────────────────────────────────────────────
# Distribution / Packaging
# ─────────────────────────────────────────────
build/
dist/
*.egg
*.egg-info/
.eggs/
wheels/
sdist/
*.manifest
*.spec

# ─────────────────────────────────────────────
# Tests & Coverage
# ─────────────────────────────────────────────
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.cache

# ─────────────────────────────────────────────
# Jupyter Notebook
# ─────────────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────────────
# Type checkers & linters
# ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ─────────────────────────────────────────────
# Données — sources brutes et datasets lourds
# Le contenu est exclu, les .gitkeep sont préservés
# ─────────────────────────────────────────────
data/raw/**
data/external/**
!data/raw/.gitkeep
!data/raw/**/.gitkeep
!data/external/.gitkeep
!data/external/**/.gitkeep

# Exception : on autorise les petits CSV processés à figurer dans data/processed/
# Pour exclure des fichiers lourds spécifiques, ajouter des règles ciblées
# Exemple :  data/processed/huge_file.parquet

# ─────────────────────────────────────────────
# Secrets & configuration locale
# ─────────────────────────────────────────────
.env
.env.*
*.key
secrets.json
config/credentials.json

# ─────────────────────────────────────────────
# IDE & éditeurs
# ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
.spyderproject
.spyproject
.ropeproject

# ─────────────────────────────────────────────
# Système d'exploitation
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# Temporaires et logs
# ─────────────────────────────────────────────
*.log
*.tmp
*.bak
